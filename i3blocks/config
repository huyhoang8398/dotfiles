# Mediaplayer
#

[focusedwindow]
label=[]= 
command=./test
interval=persist

# Spotify icon \uF1BC
[spotify]
label= 
command=./spotify.py
interval=5

# Backlight
#
[brightness]
command=./backlight
label=☀ 
interval=once
signal=13

# Volume
#
[volume]
command=./volume
LABEL=♪ 
interval=once
signal=10

# Temperature
#
[Temperature]
command=./temperature
label= 
interval=30

# Battery
#
[battery]
command=./battery
interval=30
LABEL=⚡

# Date Time
#
[time]
command=date '+%H:%M %d-%m-%Y'
interval=5
