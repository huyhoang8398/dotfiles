! X colors.
! Generated by 'wal'
*foreground:        #e5e1ce
*background:        #141b1e
*.foreground:       #e5e1ce
*.background:       #141b1e
emacs*foreground:   #e5e1ce
emacs*background:   #141b1e
URxvt*foreground:   #e5e1ce
XTerm*foreground:   #e5e1ce
UXTerm*foreground:  #e5e1ce
URxvt*background:   [100]#141b1e
XTerm*background:   #141b1e
UXTerm*background:  #141b1e
URxvt*cursorColor:  #e5e1ce
XTerm*cursorColor:  #e5e1ce
UXTerm*cursorColor: #e5e1ce
URxvt*borderColor:  [100]#141b1e

! Colors 0-15.
*.color0: #141b1e
*color0:  #141b1e
*.color1: #9A9C73
*color1:  #9A9C73
*.color2: #C8AA58
*color2:  #C8AA58
*.color3: #4F7884
*color3:  #4F7884
*.color4: #5D9896
*color4:  #5D9896
*.color5: #4BB2BB
*color5:  #4BB2BB
*.color6: #A5A993
*color6:  #A5A993
*.color7: #e5e1ce
*color7:  #e5e1ce
*.color8: #a09d90
*color8:  #a09d90
*.color9: #9A9C73
*color9:  #9A9C73
*.color10: #C8AA58
*color10:  #C8AA58
*.color11: #4F7884
*color11:  #4F7884
*.color12: #5D9896
*color12:  #5D9896
*.color13: #4BB2BB
*color13:  #4BB2BB
*.color14: #A5A993
*color14:  #A5A993
*.color15: #e5e1ce
*color15:  #e5e1ce

! Black color that will not be affected by bold highlighting.
*.color66: #141b1e
*color66:  #141b1e

! Xclock colors.
XClock*foreground: #e5e1ce
XClock*background: #141b1e
XClock*majorColor:  rgba:e5/e1/ce/ff
XClock*minorColor:  rgba:e5/e1/ce/ff
XClock*hourColor:   rgba:e5/e1/ce/ff
XClock*minuteColor: rgba:e5/e1/ce/ff
XClock*secondColor: rgba:e5/e1/ce/ff

! Set depth to make transparency work.
URxvt*depth: 32
