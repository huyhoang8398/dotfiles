! X colors.
! Generated by 'wal'
*foreground:        #dbcdca
*background:        #040C14
*.foreground:       #dbcdca
*.background:       #040C14
emacs*foreground:   #dbcdca
emacs*background:   #040C14
URxvt*foreground:   #dbcdca
XTerm*foreground:   #dbcdca
UXTerm*foreground:  #dbcdca
URxvt*background:   [100]#040C14
XTerm*background:   #040C14
UXTerm*background:  #040C14
URxvt*cursorColor:  #dbcdca
XTerm*cursorColor:  #dbcdca
UXTerm*cursorColor: #dbcdca
URxvt*borderColor:  [100]#040C14

! Colors 0-15.
*.color0: #040C14
*color0:  #040C14
*.color1: #2F5168
*color1:  #2F5168
*.color2: #625354
*color2:  #625354
*.color3: #8D3E3A
*color3:  #8D3E3A
*.color4: #8F6F6C
*color4:  #8F6F6C
*.color5: #8C7E83
*color5:  #8C7E83
*.color6: #AC9190
*color6:  #AC9190
*.color7: #dbcdca
*color7:  #dbcdca
*.color8: #998f8d
*color8:  #998f8d
*.color9: #2F5168
*color9:  #2F5168
*.color10: #625354
*color10:  #625354
*.color11: #8D3E3A
*color11:  #8D3E3A
*.color12: #8F6F6C
*color12:  #8F6F6C
*.color13: #8C7E83
*color13:  #8C7E83
*.color14: #AC9190
*color14:  #AC9190
*.color15: #dbcdca
*color15:  #dbcdca

! Black color that will not be affected by bold highlighting.
*.color66: #040C14
*color66:  #040C14

! Xclock colors.
XClock*foreground: #dbcdca
XClock*background: #040C14
XClock*majorColor:  rgba:db/cd/ca/ff
XClock*minorColor:  rgba:db/cd/ca/ff
XClock*hourColor:   rgba:db/cd/ca/ff
XClock*minuteColor: rgba:db/cd/ca/ff
XClock*secondColor: rgba:db/cd/ca/ff

! Set depth to make transparency work.
URxvt*depth: 32
